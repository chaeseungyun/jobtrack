# Supabase — 환경별로 다른 프로젝트 사용
# Development/Test: 개발용 Supabase 프로젝트
# Production: 프로덕션 전용 Supabase 프로젝트 (Vercel Production 환경변수로 설정)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Auth — 프로덕션과 개발 환경에서 별도 시크릿 사용 권장
JWT_SECRET=your-jwt-secret

# External Services
SCRAPINGBEE_API_KEY=your-scrapingbee-key
OPENAI_API_KEY=your-openai-key
RESEND_API_KEY=your-resend-key

# Cron — Vercel Cron 인증용
CRON_SECRET=your-cron-secret

# Site URL (이메일 링크 등에 사용)
# NEXT_PUBLIC_SITE_URL=https://jobtrack-phi.vercel.app
